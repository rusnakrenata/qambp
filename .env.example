# Copy this file to .env and fill in your own values.
# .env is gitignored and must never be committed.

# --- MariaDB / MySQL connection -------------------------------------------
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_HOST=localhost
DB_PORT=3306
DB_NAME=graphPartitioning

# --- D-Wave Leap credentials ----------------------------------------------
# Either set the API token directly...
DWAVE_API_TOKEN=your_leap_api_token

# ...or leave DWAVE_API_TOKEN empty and point to a named profile in
# ~/.config/dwave/dwave.conf (created with `dwave config create`).
# DWAVE_PROFILE=defaults
